+  def resource_clearance_score(center_x, center_y, resources):
+    score = 0
+    for resource in resources:
+      distance = math.sqrt((resource.x - center_x) ** 2 + (resource.y - center_y) ** 2)
+      if resource.unit_type in GAS_TYPE:
+        minimum, ideal, maximum = 7 * ratio, 8.5 * ratio, 10 * ratio
+      else:
+        minimum, ideal, maximum = 6 * ratio, 7.5 * ratio, 9 * ratio
+      if not (minimum < distance < maximum):
+        return None
+      score += (distance - ideal) ** 2
+    return score
